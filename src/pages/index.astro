---
const defaultPlayer = 'MocroPapi';
const response = await fetch(`https://api.chess.com/pub/player/${defaultPlayer}`);
const data = await response.json();
const statsResponse = await fetch(`https://api.chess.com/pub/player/${defaultPlayer}/stats`);
const statsData = await statsResponse.json();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Boss op chess</title>
    <style>
      body { font-family: sans-serif; padding: 2rem; text-align: center; }
      input { padding: 0.5rem; margin-right: 0.5rem; }
      img { max-width: 150px; border-radius: 50%; margin-top: 1rem; }
      ul { list-style: none; padding-left: 0; text-align: left; display: inline-block; margin-top: 1rem; }
      li { margin-bottom: 0.5rem; }
    </style>
  </head>
  <body>
    <h1>Boss op chess</h1>

    <input type="text" id="username" placeholder="Enter Chess.com username" />
    <button id="searchBtn">Search</button>

    <div id="playerContainer">
      <img id="playerAvatar" src={data.avatar ?? ''} alt="Avatar" />
      {!data.avatar && <p>No avatar available</p>}
      <ul id="playerInfo">
        <li><strong>Username:</strong> {data.username}</li>
        <li><strong>Name:</strong> {data.name ?? 'N/A'}</li>
        <li><strong>Rapid ELO:</strong> {statsData.chess_rapid?.last?.rating ?? 'N/A'}</li>
        <li><strong>Country:</strong> {data.country ?? 'N/A'}</li>
        <li><strong>Joined:</strong> {data.joined ? new Date(data.joined*1000).toLocaleDateString() : 'N/A'}</li>
      </ul>
    </div>

    <script>
      const searchBtn = document.getElementById('searchBtn');
      const usernameInput = document.getElementById('username');
      const playerContainer = document.getElementById('playerContainer');
      const playerInfo = document.getElementById('playerInfo');

      async function fetchPlayerProfile(username) {
        try {
          const profileResp = await fetch(`https://api.chess.com/pub/player/${username}`);
          if (!profileResp.ok) {
            playerContainer.innerHTML = '<p>Player not found</p>';
            return;
          }
          const profile = await profileResp.json();

      
          const statsResp = await fetch(`https://api.chess.com/pub/player/${username}/stats`);
          const stats = await statsResp.json();

      
          playerContainer.innerHTML = `
            <img src="${profile.avatar ?? ''}" alt="Avatar" />
            ${!profile.avatar ? '<p>No avatar available</p>' : ''}
            <ul>
              <li><strong>Username:</strong> ${profile.username}</li>
              <li><strong>Name:</strong> ${profile.name ?? 'N/A'}</li>
              <li><strong>Rapid ELO:</strong> ${stats.chess_rapid?.last?.rating ?? 'N/A'}</li>
              <li><strong>Country:</strong> ${profile.country ?? 'N/A'}</li>
              <li><strong>Joined:</strong> ${profile.joined ? new Date(profile.joined*1000).toLocaleDateString() : 'N/A'}</li>
            </ul>
          `;
        } catch (err) {
          console.error(err);
          playerContainer.innerHTML = '<p>Error fetching player</p>';
        }
      }

      searchBtn.addEventListener('click', () => {
        const username = usernameInput.value.trim();
        if (username) fetchPlayerProfile(username);
      });

      usernameInput.addEventListener('keyup', (e) => {
        if (e.key === 'Enter') {
          const username = usernameInput.value.trim();
          if (username) fetchPlayerProfile(username);
        }
      });
    </script>
  </body>
</html>